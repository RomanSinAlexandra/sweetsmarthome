<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/light_bg">

    <com.skydoves.colorpickerview.ColorPickerView
        android:id="@+id/colorPicker"
        android:layout_width="320dp"
        android:layout_height="320dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:palette="@drawable/ic_color_wheel"
        app:selector="@drawable/ic_color_selector" />

    <me.tankery.lib.circularseekbar.CircularSeekBar
        android:id="@+id/circularSeekBar"
        android:layout_width="360dp"
        android:layout_height="360dp"
        app:cs_circle_color="#33FFFFFF"
        app:cs_circle_progress_color="#00FF00"
        app:cs_circle_stroke_width="8dp"
        app:cs_circle_style="round"
        app:cs_max="360"
        app:cs_pointer_color="#FFFFFF"
        app:cs_pointer_stroke_width="16dp"
        app:layout_constraintBottom_toBottomOf="@id/colorPicker"
        app:layout_constraintEnd_toEndOf="@id/colorPicker"
        app:layout_constraintStart_toStartOf="@id/colorPicker"
        app:layout_constraintTop_toTopOf="@id/colorPicker" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/currentColorCenter"
        android:layout_width="180dp"
        android:layout_height="180dp"
        app:cardBackgroundColor="#FFFF00"
        app:cardCornerRadius="90dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/colorPicker"
        app:layout_constraintEnd_toEndOf="@id/colorPicker"
        app:layout_constraintStart_toStartOf="@id/colorPicker"
        app:layout_constraintTop_toTopOf="@id/colorPicker" />

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B31A1A2E"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_brightness_low"
                app:tint="#FFFFFF" />

            <SeekBar
                android:id="@+id/sbBrightness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:max="255"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_brightness_high"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Задаваемые\nнастройки"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorRed"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#FF0000"
                app:cardCornerRadius="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorGreen"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#00FF00"
                app:cardCornerRadius="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorBlue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#0000FF"
                app:cardCornerRadius="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorPurple"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#8A2BE2"
                app:cardCornerRadius="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorMagenta"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#FF00FF"
                app:cardCornerRadius="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnColorCyan"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#00FFFF"
                app:cardCornerRadius="6dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#33000000"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:text="Стандарт"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardLight"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#000000"
                    app:cardCornerRadius="6dp"
                    app:strokeColor="#00FF00"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="#FFFFFF" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardRgb"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="RGB"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardCyan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#00FFFF"
                    app:cardCornerRadius="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardRed"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF0000"
                    app:cardCornerRadius="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardGreen"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#00FF00"
                    app:cardCornerRadius="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStandardBlue"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#0000FF"
                    app:cardCornerRadius="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>