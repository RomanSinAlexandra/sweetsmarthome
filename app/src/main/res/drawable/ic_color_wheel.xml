<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <group
        android:pivotX="50"
        android:pivotY="50"
        android:rotation="-90">

        <path
            android:fillType="evenOdd"
            android:pathData="
                M 50,0 A 50,50 0 1,1 50,100 A 50,50 0 1,1 50,0 Z
                M 50,10 A 30,30 0 1,0 50,90 A 30,30 0 1,0 50,10 Z">

            <aapt:attr name="android:fillColor">
                <gradient
                    android:centerX="50"
                    android:centerY="50"
                    android:type="sweep">
                    <item android:color="#FF0000" android:offset="0.0" />     <item android:color="#FFFF00" android:offset="0.167" />   <item android:color="#00FF00" android:offset="0.333" />   <item android:color="#00FFFF" android:offset="0.5" />     <item android:color="#0000FF" android:offset="0.667" />   <item android:color="#FF00FF" android:offset="0.833" />   <item android:color="#FF0000" android:offset="1.0" />     </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>